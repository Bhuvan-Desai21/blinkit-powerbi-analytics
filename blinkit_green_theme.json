        "categoryLabels": [{ "color": { "solid": { "color": "#5A5F5A" } }, "fontSize": 10, "fontFamily": "Segoe UI" }]
      }
    },
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#F4F7F4" } }, "transparency": 0 }]
